rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Products: Public reading, Admin writing
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null; // Restrict writes to authenticated admin users
    }
    
    // 2. Orders: Public creation, Admin updates, read by order owner or admin
    match /orders/{orderId} {
      allow create: if true; // Customers can checkout orders
      allow read: if true; // Allow reading orders for invoicing status checks
      allow update, delete: if request.auth != null; // Prevent customer from modifying statuses (Server Admin SDK bypasses this)
    }
    
    // 3. Contacts: Public creation, Admin reading
    match /contacts/{contactId} {
      allow create: if true;
      allow read: if request.auth != null;
    }
    
    // 4. Audit Logs: Public creation (for client tracking), Admin reading
    match /audit_logs/{logId} {
      allow create: if true;
      allow read: if request.auth != null;
    }
  }
}
