rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public reading of product images, write restricts to admins with file restrictions
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null // Requires authenticated admin session
                   && request.resource.size < 5 * 1024 * 1024 // Size limit <= 5 MB
                   && request.resource.contentType.matches('image/(jpeg|png|webp|jpg)'); // Supported formats
    }
  }
}
